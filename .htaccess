Options -Indexes
RewriteEngine On
RewriteBase /

# -----------------------------------------------
# 301 Redirects: old pages/*.php → clean URLs
# -----------------------------------------------
RewriteRule ^pages/hosting\.php$   /hosting   [R=301,L]
RewriteRule ^pages/domains\.php$   /domains   [R=301,L]
RewriteRule ^pages/webdesign\.php$ /webdesign [R=301,L]
RewriteRule ^pages/email\.php$     /email     [R=301,L]
RewriteRule ^pages/security\.php$  /security  [R=301,L]
RewriteRule ^pages/contact\.php$   /contact   [R=301,L]

# -----------------------------------------------
# Clean URLs → internal rewrite to pages/*.php
# -----------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^hosting/?$   pages/hosting.php   [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^domains/?$   pages/domains.php   [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^webdesign/?$ pages/webdesign.php [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^email/?$     pages/email.php     [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^security/?$  pages/security.php  [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^contact/?$   pages/contact.php   [L,QSA]

# -----------------------------------------------
# Root → index.php
# -----------------------------------------------
RewriteRule ^$ index.php [L,QSA]
