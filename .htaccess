Options -Indexes
RewriteEngine On
RewriteBase /

# -----------------------------------------------
# 301 Redirects: old pages/*.php -> clean URLs
# THE_REQUEST = original browser request line,
# so internal rewrites do NOT trigger these rules
# -----------------------------------------------
RewriteCond %{THE_REQUEST} \s/+pages/hosting\.php [NC]
RewriteRule ^ /hosting [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/domains\.php [NC]
RewriteRule ^ /domains [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/webdesign\.php [NC]
RewriteRule ^ /webdesign [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/email\.php [NC]
RewriteRule ^ /email [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/security\.php [NC]
RewriteRule ^ /security [R=301,L]

RewriteCond %{THE_REQUEST} \s/+pages/contact\.php [NC]
RewriteRule ^ /contact [R=301,L]

# -----------------------------------------------
# Clean URLs -> internal rewrite to pages/*.php
# -----------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^hosting/?$   pages/hosting.php   [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^domains/?$   pages/domains.php   [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^webdesign/?$ pages/webdesign.php [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^email/?$     pages/email.php     [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^security/?$  pages/security.php  [L,QSA]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^contact/?$   pages/contact.php   [L,QSA]

# -----------------------------------------------
# Root -> index.php
# -----------------------------------------------
RewriteRule ^$ index.php [L,QSA]
