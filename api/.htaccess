# Disable ModSecurity / Imunify360 bot challenge for API endpoints.
# All directives wrapped in <IfModule> so missing modules cause NO error.

<IfModule mod_security2.c>
    SecRuleEngine Off
</IfModule>

<IfModule mod_security.c>
    SecFilterEngine Off
    SecFilterScanPOST Off
</IfModule>

# SetEnvIf is part of mod_setenvif which is almost always available
<IfModule mod_setenvif.c>
    SetEnvIfNoCase X-Requested-With XMLHttpRequest ajax_request
</IfModule>
